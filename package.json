{
  "name": "docusnap",
  "version": "2.0.0",
  "description": "Open-source Javascript document scanner with auto-capture and quality assessment.",
  "main": "src/docusnap-node.js",
  "exports": {
    ".": {
      "default": "./src/docusnap-node.js"
    },
    "./client": {
      "default": "./src/docusnap.js"
    },
    "./quality": {
      "default": "./src/quality.js"
    },
    "./auto-capture": {
      "default": "./src/document-auto-capture.js"
    }
  },
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "mocha --trace-uncaught"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/petermartis/docuSnap.git"
  },
  "keywords": [
    "js",
    "scanner",
    "document-scanner"
  ],
  "author": "petermartis",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/petermartis/docuSnap/issues"
  },
  "homepage": "https://petermartis.github.io/docuSnap/",
  "dependencies": {
    "canvas": "^3.1.0",
    "jsdom": "^26.0.0"
  },
  "devDependencies": {
    "mocha": "^11.1.0"
  }
}
